{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thediamonddealer.github.io/market-brief/schemas/cot-contract-registry.schema.json",
  "title": "Market Brief exact COT contract registry",
  "type": "object",
  "required": ["schemaVersion", "source", "referenceProductIds", "contracts"],
  "properties": {
    "schemaVersion": {"const": 1},
    "source": {
      "type": "object",
      "required": ["name", "url", "disaggregatedDatasetId", "tradersInFinancialFuturesDatasetId"]
    },
    "referenceProductIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "status", "reportType", "category", "datasetId", "cftcContractCode", "expectedExchange", "acceptedNames", "rejectedTerms", "maximumAgeDays"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "status": {"enum": ["verified", "unavailable"]},
          "reportType": {"enum": ["disaggregated", "traders-in-financial-futures"]},
          "category": {"enum": ["Managed money", "Leveraged funds"]},
          "datasetId": {"enum": ["72hh-3qpy", "gpe5-46if"]},
          "cftcContractCode": {"type": ["string", "null"], "pattern": "^[0-9A-Z+]{6}$"},
          "expectedExchange": {"type": ["string", "null"]},
          "acceptedNames": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "rejectedTerms": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "maximumAgeDays": {"type": "integer", "minimum": 1},
          "legacyIds": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "historicalCftcContractCode": {"type": "string", "pattern": "^[0-9A-Z+]{6}$"},
          "lastObservationDate": {"type": "string", "format": "date"},
          "unavailableReason": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"status": {"const": "verified"}}},
            "then": {
              "properties": {
                "cftcContractCode": {"type": "string", "pattern": "^[0-9A-Z+]{6}$"},
                "expectedExchange": {"type": "string", "minLength": 1},
                "acceptedNames": {"minItems": 1}
              }
            },
            "else": {
              "required": ["unavailableReason"],
              "properties": {
                "cftcContractCode": {"type": "null"},
                "expectedExchange": {"type": "null"},
                "acceptedNames": {"maxItems": 0}
              }
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
