{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thediamonddealer.github.io/market-brief/schemas/free-market-data.schema.json",
  "title": "Market Brief free market data",
  "type": "object",
  "required": ["generatedAt", "generatedAtUtc", "rates", "curveSpreads", "cot", "sourceStatus", "methodology"],
  "properties": {
    "generatedAt": {"type": "string", "minLength": 1},
    "generatedAtUtc": {"type": "string", "minLength": 1},
    "rates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "unit", "kind", "date", "value", "sourceUrl"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "unit": {"type": "string"},
          "kind": {"type": "string"},
          "date": {"type": "string", "minLength": 8},
          "value": {"type": "number"},
          "previous": {"type": ["number", "null"]},
          "change": {"type": ["number", "null"]},
          "changeBps": {"type": ["number", "null"]},
          "sourceUrl": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "curveSpreads": {"type": "array"},
    "cot": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "market", "category", "reportDate", "long", "short", "net", "source", "sourceUrl"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "market": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "reportDate": {"type": "string", "minLength": 8},
          "long": {"type": "number"},
          "short": {"type": "number"},
          "net": {"type": "number"},
          "source": {"type": "string", "minLength": 1},
          "sourceUrl": {"type": "string", "minLength": 1},
          "history52": {"type": "array"}
        },
        "additionalProperties": true
      }
    },
    "sourceStatus": {"type": "array"},
    "methodology": {"type": "object"}
  },
  "additionalProperties": true
}
