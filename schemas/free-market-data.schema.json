{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thediamonddealer.github.io/market-brief/schemas/free-market-data.schema.json",
  "title": "Market Brief free market data",
  "type": "object",
  "required": ["generatedAt", "generatedAtUtc", "rates", "curveSpreads", "cot", "sourceStatus", "methodology"],
  "properties": {
    "generatedAt": {"type": "string", "minLength": 1},
    "generatedAtUtc": {"type": "string", "minLength": 1},
    "rates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "unit", "kind", "date", "value", "sourceUrl"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "unit": {"type": "string"},
          "kind": {"type": "string"},
          "date": {"type": "string", "minLength": 8},
          "value": {"type": "number"},
          "previous": {"type": ["number", "null"]},
          "change": {"type": ["number", "null"]},
          "changeBps": {"type": ["number", "null"]},
          "sourceUrl": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "curveSpreads": {"type": "array"},
    "cot": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "market", "category", "reportDate", "long", "short", "net", "source", "sourceUrl"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "market": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "reportDate": {"type": "string", "minLength": 8},
          "long": {"type": "number"},
          "short": {"type": "number"},
          "net": {"type": "number"},
          "source": {"type": "string", "minLength": 1},
          "sourceUrl": {"type": "string", "minLength": 1},
          "history52": {"type": "array"},
          "contract": {
            "type": "object",
            "required": ["registryVersion", "identityStatus", "cftcContractCode", "reportType", "category", "exchange", "marketName"],
            "properties": {
              "registryVersion": {"const": 1},
              "identityStatus": {"const": "verified"},
              "cftcContractCode": {"type": "string", "pattern": "^[0-9A-Z+]{6}$"},
              "reportType": {"enum": ["disaggregated", "traders-in-financial-futures"]},
              "category": {"enum": ["Managed money", "Leveraged funds"]},
              "exchange": {"type": "string", "minLength": 1},
              "marketName": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "cotContractRegistry": {
      "type": "object",
      "required": ["schemaVersion", "verifiedIds", "unavailable"],
      "properties": {
        "schemaVersion": {"const": 1},
        "verifiedIds": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "unavailable": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "reason"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "label": {"type": "string", "minLength": 1},
              "reason": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "sourceStatus": {"type": "array"},
    "methodology": {"type": "object"}
  },
  "additionalProperties": true
}
