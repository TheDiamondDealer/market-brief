{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thediamonddealer.github.io/market-brief/schemas/news-impact.schema.json",
  "title": "Market Brief curated news impact contract",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "sourceMode", "items"],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAt": {"type": ["string", "null"]},
    "sourceMode": {"const": "curated-delayed"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "status", "eventDate", "headline", "summary", "sources", "interpretations"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "status": {"enum": ["developing", "confirmed", "resolved", "diverging", "unclear"]},
          "eventDate": {"type": ["string", "null"], "pattern": "^$|^\\d{4}-\\d{2}-\\d{2}$"},
          "timeLabel": {"type": "string"},
          "headline": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "url"],
              "properties": {
                "name": {"type": "string", "minLength": 1},
                "url": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "interpretations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["assetId", "assetName", "direction", "magnitude", "horizon", "confidence", "mechanism", "confirmation", "invalidation"],
              "properties": {
                "assetId": {"type": "string", "minLength": 1},
                "assetName": {"type": "string", "minLength": 1},
                "direction": {"enum": ["up", "down", "mixed", "unclear"]},
                "magnitude": {"enum": ["high", "medium", "low", "unclear"]},
                "horizon": {"enum": ["immediate", "session", "days", "weeks", "unclear"]},
                "confidence": {"enum": ["high", "medium", "low", "unclear"]},
                "mechanism": {"type": "string", "minLength": 1},
                "confirmation": {"type": "string", "minLength": 1},
                "invalidation": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "detail"],
              "properties": {
                "label": {"type": "string", "minLength": 1},
                "detail": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "legacy": {
            "type": "object",
            "properties": {
              "impact": {"type": "string"},
              "status": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
