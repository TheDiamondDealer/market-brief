{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thediamonddealer.github.io/market-brief/schemas/gdelt-radar.schema.json",
  "title": "Market Brief GDELT Discovery Radar",
  "type": "object",
  "required": ["schemaVersion", "generatedAtUtc", "provider", "collection", "disclaimer", "topics", "articles", "sourceStatus", "methodology"],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAtUtc": {"type": ["string", "null"]},
    "provider": {
      "type": "object",
      "required": ["id", "name", "readOnly", "documentationUrl"],
      "properties": {
        "id": {"const": "gdelt-doc-2"},
        "name": {"type": "string"},
        "readOnly": {"const": true},
        "documentationUrl": {"type": "string", "format": "uri"}
      },
      "additionalProperties": false
    },
    "collection": {
      "type": "object",
      "required": ["status", "expectedCadence", "queryCount", "successfulQueryCount", "rawArticleCount", "selectedArticleCount", "lastSuccessfulAt", "error"],
      "properties": {
        "status": {"enum": ["current", "partial", "stale", "failed", "unavailable"]},
        "expectedCadence": {"type": "string"},
        "queryCount": {"type": "integer", "minimum": 0},
        "successfulQueryCount": {"type": "integer", "minimum": 0},
        "rawArticleCount": {"type": "integer", "minimum": 0},
        "selectedArticleCount": {"type": "integer", "minimum": 0, "maximum": 48},
        "lastSuccessfulAt": {"type": ["string", "null"]},
        "error": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "disclaimer": {"type": "string", "minLength": 20},
    "topics": {"type": "array"},
    "articles": {
      "type": "array",
      "maxItems": 48,
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "domain", "topicIds", "topics", "assets", "materialityScore", "sourceTier", "verificationStatus", "verificationNote", "duplicateCount"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string", "minLength": 20, "maxLength": 320},
          "url": {"type": "string", "format": "uri"},
          "domain": {"type": "string"},
          "language": {"type": "string"},
          "sourceCountry": {"type": "string"},
          "seenAt": {"type": ["string", "null"]},
          "firstSeenAt": {"type": ["string", "null"]},
          "topicIds": {"type": "array", "items": {"type": "string"}},
          "topics": {"type": "array", "items": {"type": "string"}},
          "assets": {"type": "array", "items": {"type": "string"}},
          "materialityScore": {"type": "integer", "minimum": 0, "maximum": 100},
          "sourceTier": {"const": "discovery"},
          "verificationStatus": {"const": "unverified"},
          "verificationNote": {"type": "string"},
          "duplicateCount": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "sourceStatus": {"type": "array", "minItems": 1, "maxItems": 1},
    "methodology": {"type": "object"}
  },
  "additionalProperties": false
}
